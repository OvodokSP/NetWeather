<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Верхняя часть: индекс и режим -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Индекс доступности -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_availability_index"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Доступность"
                android:textSize="11sp"
                android:textColor="@color/widget_text_secondary" />

        </LinearLayout>

        <!-- Режим сети -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_network_mode_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tv_network_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нормальный"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Нижняя часть: время последней проверки -->
    <TextView
        android:id="@+id/tv_last_check_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Обновлено: --:--"
        android:textSize="11sp"
        android:textColor="@color/widget_text_secondary"
        android:gravity="center" />

</LinearLayout>